import { useState, useMemo } from "react";

const C = {
  green:"#1a6b3c", greenLight:"#2d9158", greenFade:"rgba(26,107,60,0.08)",
  gold:"#e8a020", goldFade:"rgba(232,160,32,0.1)",
  cream:"#faf6ef", dark:"#0f1f13", text:"#2a3d2e", muted:"#6b7f6e",
  white:"#fff", red:"#d94040", redFade:"rgba(217,64,64,0.08)",
  border:"rgba(26,107,60,0.1)",
};
const fmt = n => "₦" + Number(n||0).toLocaleString("en-NG");
const today = () => new Date().toISOString().split("T")[0];
const getWeek = d => { const dt=new Date(d); dt.setDate(dt.getDate()-dt.getDay()); return dt.toISOString().split("T")[0]; };
const getMonth = d => d.slice(0,7);

