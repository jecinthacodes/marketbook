                  <div style={{height:5,borderRadius:3,background:"rgba(0,0,0,0.06)"}}><div style={{height:"100%",borderRadius:3,background:catColors[x.cat],width:`${(x.total/totalAll)*100}%`,transition:"width 0.5s"}}/></div>
                </div>
